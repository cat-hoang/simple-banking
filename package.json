{
  "name": "banking-transfer-service",
  "version": "1.0.0",
  "description": "A simple banking transfer service: load account balances and apply a day's transfers from CSV.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start": "tsx src/run.ts",
    "run:sample": "tsx src/run.ts sample_files/mable_account_balances.csv sample_files/mable_transactions.csv",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --check ."
  },
  "keywords": [
    "banking",
    "csv",
    "typescript"
  ],
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.0.0",
    "@vitest/coverage-v8": "^3.2.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^9.1.2",
    "prettier": "^3.9.4",
    "tsx": "^4.19.0",
    "typescript": "^5.9.0",
    "typescript-eslint": "^8.62.1",
    "vitest": "^3.2.0"
  }
}
